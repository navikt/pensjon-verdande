{
  "name": "pensjon-verdande",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "react-router build",
    "build:server": "tsc --project server/tsconfig.json",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "react-router dev",
    "dev:q2": "PEN_URL=https://pensjon-pen-q2.dev.adeo.no react-router dev",
    "fetch-secrets": "./fetch-secrets.sh",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "start": "react-router-serve ./build/server/index.js",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "build-storybook": "STORYBOOK=true storybook build",
    "capture-screenshots": "npx tsx scripts/capture-screenshots.ts",
    "capture-docs-screenshots": "npx tsx scripts/capture-screenshots.ts --docs",
    "test": "vitest --project unit",
    "test:stories": "vitest --project storybook",
    "typecheck": "node scripts/copy-server-dts.ts && react-router typegen && tsc"
  },
  "dependencies": {
    "@mjackson/form-data-parser": "^0.9.1",
    "@navikt/aksel-icons": "^8.11.0",
    "@navikt/ds-css": "^8.11.0",
    "@navikt/ds-react": "^8.11.0",
    "@react-router/express": "7.16.0",
    "@react-router/node": "7.16.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^5.2.1",
    "isbot": "^5.1.39",
    "jwt-decode": "^4.0.0",
    "node-cache": "^5.1.2",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.5",
    "react-router": "7.16.0",
    "remix-auth": "^4.2.0",
    "remix-auth-oauth2": "^3.4.1",
    "tiny-invariant": "^1.3.3",
    "winston": "^3.19.0",
    "xml-formatter": "^3.7.0",
    "zod": "^4.4.3",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@react-router/dev": "7.16.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.5",
    "csstype": "^3.2.3",
    "jsdom": "^29.1.0",
    "lefthook": "^2.1.9",
    "playwright": "^1.58.2",
    "react-router-devtools": "^6.2.0",
    "storybook": "^10.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": "^24.11.0"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
